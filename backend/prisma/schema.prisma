generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =========================
// ENUMS
// =========================

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum PaymentStatus {
  PAID
  PENDING
  PARTIAL
  REFUNDED
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  ONLINE
  BANK_TRANSFER
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// =========================
// USER
// =========================

model User {
  id       String  @id @default(uuid())
  fullName String
  email    String  @unique
  password String
  phone    String?
  location String?
  role     Role    @default(ADMIN)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Kis user ne is user ko create kiya
  createdById String?

  creator User? @relation("UserCreator", fields: [createdById], references: [id])

  // Is user ne kitne users create kiye
  createdUsers User[] @relation("UserCreator")

  products Product[]
  invoices Invoice[]
  payments Payment[]
  returns  Return[]
  audits   Audit[]
}

// =========================
// PRODUCT
// =========================

model Product {
  id           String  @id @default(uuid())
  productName  String
  productImage String?
  stock        Int     @default(0)
  sellingPrice Float

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  invoiceItems InvoiceItem[]

  // Added because Payment has productId
  payments Payment[]

  returns Return[]
}

// =========================
// INVOICE
// =========================

model Invoice {
  id            String @id @default(uuid())
  invoiceNumber String @unique

  // Optional one-to-one payment relation
  paymentId String?  @unique
  payment   Payment? @relation(fields: [paymentId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  customerName String
  currency     String @default("INR")

  subTotal       Decimal @default(0) @db.Decimal(15, 2)
  discountAmount Decimal @default(0) @db.Decimal(15, 2)
  totalAmount    Decimal @default(0) @db.Decimal(15, 2)
  paidAmount     Decimal @default(0) @db.Decimal(15, 2)
  dueAmount      Decimal @default(0) @db.Decimal(15, 2)

  status InvoiceStatus @default(PENDING)

  items     InvoiceItem[]
  discounts Discount[]
  returns   Return[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([paymentId])
  @@index([userId])
}

// =========================
// INVOICE ITEM
// =========================

model InvoiceItem {
  id String @id @default(uuid())

  quantity Int
  price    Float
  gst      Float @default(0)
  total    Float

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

// =========================
// DISCOUNT
// =========================

model Discount {
  id             String       @id @default(uuid())
  discountType   DiscountType
  discountValue  Float
  discountAmount Float

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =========================
// PAYMENT
// =========================

model Payment {
  id            String @id @default(uuid())
  paymentNumber String @unique

  userId String
  user   User   @relation(fields: [userId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  customerName String
  quantity     Int

  price      Decimal @db.Decimal(15, 2)
  totalPrice Decimal @db.Decimal(15, 2)

  discountValue   Decimal @default(0) @db.Decimal(15, 2)
  discountPercent Decimal @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal @default(0) @db.Decimal(15, 2)

  finalPrice Decimal @db.Decimal(15, 2)

  paymentMethod PaymentMethod
  amount        Decimal       @db.Decimal(15, 2)
  currency      String        @default("INR")
  paymentStatus PaymentStatus @default(PENDING)

  // Opposite relation of Invoice.payment
  invoice Invoice?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([productId])
}

// =========================
// RETURN
// =========================

model Return {
  id           String   @id @default(uuid())
  returnNumber String   @unique
  returnDate   DateTime @default(now())

  productName  String
  productImage String?

  subTotal     Float        @default(0)
  grandTotal   Float        @default(0)
  refundStatus RefundStatus @default(PENDING)

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
}

// =========================
// AUDIT
// =========================

model Audit {
  id       String @id @default(uuid())
  action   String
  table    String
  oldValue Json?
  newValue Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy String?
  updatedBy String?

  userId String
  user   User   @relation(fields: [userId], references: [id])
}
