generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum PaymentStatus {
  PAID
  PENDING
  PARTIAL
  REFUNDED
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

model User {
  id       String  @id @default(uuid())
  fullName String
  email    String  @unique
  password String
  phone    String?
  location String?
  role     Role    @default(ADMIN)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // kis user ne is user ko create kiya
  createdById String?
  creator     User?   @relation("UserCreator", fields: [createdById], references: [id])

  // is user ne kitne users create kiye
  createdUsers User[] @relation("UserCreator")

  products Product[]
  invoices Invoice[]
  payments Payment[]
  returns  Return[]
  audits   Audit[]
}

model Product {
  id           String  @id @default(uuid())
  productName  String
  productImage String?
  stock        Int     @default(0)
  sellingPrice Float

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  invoiceItems InvoiceItem[]
  returns      Return[]
}

model Invoice {
  id            String   @id @default(uuid())
  invoiceNumber String   @unique
  customerName  String
  invoiceDate   DateTime @default(now())

  subTotal       Float @default(0)
  discountValue  Float @default(0)
  discountAmount Float @default(0)
  gst            Float @default(0)
  grandTotal     Float @default(0)
  paidAmount     Float @default(0)
  dueAmount      Float @default(0)

  paymentMethod String?
  paymentStatus PaymentStatus @default(PENDING)

  createdBy String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items     InvoiceItem[]
  discounts Discount[]

  returns Return[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvoiceItem {
  id String @id @default(uuid())

  quantity Int
  price    Float
  gst      Float @default(0)
  total    Float

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

model Discount {
  id             String       @id @default(uuid())
  discountType   DiscountType
  discountValue  Float
  discountAmount Float

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payment {
  id           String @id @default(uuid())
  customerName String
  productName  String

  quantity   Int
  price      Float
  totalPrice Float

  discountValue   Float @default(0)
  discountPercent Float @default(0)
  discountAmount  Float @default(0)
  finalPrice      Float @default(0)

  paymentNumber String        @unique
  paymentDate   DateTime      @default(now())
  paymentMethod String
  amount        Float
  currency      String        @default("INR")
  paymentStatus PaymentStatus @default(PENDING)

  createdBy String?
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

model Return {
  id           String   @id @default(uuid())
  returnNumber String   @unique
  returnDate   DateTime @default(now())

  productName  String
  productImage String?

  subTotal     Float        @default(0)
  grandTotal   Float        @default(0)
  refundStatus RefundStatus @default(PENDING)

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
}

model Audit {
  id       String @id @default(uuid())
  action   String
  table    String
  oldValue Json?
  newValue Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy String?
  updatedBy String?

  userId String
  user   User   @relation(fields: [userId], references: [id])
}
