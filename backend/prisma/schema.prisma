generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// =========================
// ENUMS
// =========================

enum Role {
  SUPER_ADMIN
  ADMIN
  USER
}

enum PaymentStatus {
  PAID
  PENDING
  PARTIAL
  REFUNDED
}

enum InvoiceStatus {
  PENDING
  PARTIAL
  PAID
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  CASH
  UPI
  CARD
  ONLINE
  BANK_TRANSFER
}

enum RefundStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

// =========================
// REPORT ENUMS
// =========================

enum ReportType {
  DAILY
  WEEKLY
  MONTHLY
  ANNUAL
}

enum ReportFormat {
  JSON
  PDF
  EXCEL
  CSV
}

enum ReportStatus {
  GENERATING
  COMPLETED
  FAILED
}

// =========================
// USER
// =========================

model User {
  id       String  @id @default(uuid())
  fullName String
  email    String  @unique
  password String
  phone    String?
  location String?
  role     Role    @default(ADMIN)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  // Kis user ne is user ko create kiya
  createdById String?

  creator User? @relation("UserCreator", fields: [createdById], references: [id])

  // Is user ne kitne users create kiye
  createdUsers User[] @relation("UserCreator")

  products       Product[]
  invoices       Invoice[]
  payments       Payment[]
  returns        Return[]
  audits         Audit[]
  createdCoupons Coupon[]

  // Report history
  reports Report[]
}

// =========================
// PRODUCT
// =========================

model Product {
  id           String  @id @default(uuid())
  productName  String
  productImage String?
  stock        Int     @default(0)
  // Purchase price (Cost Price)
  productPrice Float

  // GST Percentage
  gst          Float @default(18)
  sellingPrice Float

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  createdBy String?
  updatedBy String?
  deletedBy String?

  userId       String
  user         User          @relation(fields: [userId], references: [id])
  paymentItems PaymentItem[]

  invoiceItems InvoiceItem[]

  // Added because Payment has productId
  payments Payment[]

  returns Return[]
}

// =========================
// INVOICE
// =========================

model Invoice {
  id            String @id @default(uuid())
  invoiceNumber String @unique

  // Optional one-to-one payment relation
  paymentId String?  @unique
  payment   Payment? @relation(fields: [paymentId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  customerName String
  currency     String @default("INR")

  subTotal       Decimal @default(0) @db.Decimal(15, 2)
  discountAmount Decimal @default(0) @db.Decimal(15, 2)
  totalAmount    Decimal @default(0) @db.Decimal(15, 2)
  paidAmount     Decimal @default(0) @db.Decimal(15, 2)
  dueAmount      Decimal @default(0) @db.Decimal(15, 2)

  status InvoiceStatus @default(PENDING)

  items     InvoiceItem[]
  discounts Discount[]
  returns   Return[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([paymentId])
  @@index([userId])
}

// =========================
// INVOICE ITEM
// =========================

model InvoiceItem {
  id String @id @default(uuid())

  quantity Int
  price    Float
  gst      Float @default(0)
  total    Float

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])
}

// =========================
// DISCOUNT
// =========================

model Discount {
  id             String       @id @default(uuid())
  discountType   DiscountType
  discountValue  Float
  discountAmount Float

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =========================
// COUPON
// =========================

model Coupon {
  id String @id @default(uuid())

  couponName String
  couponCode String @unique

  discountType  DiscountType
  discountValue Float

  minOrderAmount    Float?
  maxOrderAmount    Float?
  maxDiscountAmount Float?

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdById String
  createdBy   User   @relation(fields: [createdById], references: [id])
}

// =========================
// PAYMENT
// =========================

model Payment {
  id             String        @id @default(uuid())
  paymentNumber  String        @unique
  customerName   String?
  paymentMethod  PaymentMethod
  subtotal       Float
  discountType   DiscountType?
  discountValue  Float         @default(0)
  discountAmount Float         @default(0)
  finalAmount    Float
  paidAmount     Float
  dueAmount      Float
  status         PaymentStatus
  currency       String        @default("INR")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  items     PaymentItem[]
  product   Product?      @relation(fields: [productId], references: [id])
  productId String?
  invoice   Invoice?
}

model PaymentItem {
  id String @id @default(uuid())

  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  quantity   Int
  price      Float
  totalPrice Float

  createdAt DateTime @default(now())

  @@index([paymentId])
  @@index([productId])
}

// =========================
// RETURN
// =========================

model Return {
  id           String   @id @default(uuid())
  returnNumber String   @unique
  returnDate   DateTime @default(now())

  productName  String
  productImage String?

  subTotal     Float        @default(0)
  grandTotal   Float        @default(0)
  refundStatus RefundStatus @default(PENDING)

  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
}

// =========================
// AUDIT
// =========================

model Audit {
  id       String @id @default(uuid())
  action   String
  table    String
  oldValue Json?
  newValue Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy String?
  updatedBy String?

  userId String
  user   User   @relation(fields: [userId], references: [id])
}

// =========================
// REPORT
// =========================

model Report {
  id String @id @default(uuid())

  // Example: July 2026 Monthly Report
  reportName String

  reportType ReportType
  format     ReportFormat @default(JSON)
  status     ReportStatus @default(GENERATING)

  // Report period
  startDate DateTime
  endDate   DateTime

  // Optional values used for monthly/annual reports
  day   Int?
  week  Int?
  month Int?
  year  Int?

  // Applied report filters
  filters Json?

  // Complete generated report response
  reportData Json?

  // Summary values
  totalProducts Int @default(0)
  totalUsers    Int @default(0)
  totalInvoices Int @default(0)
  totalPayments Int @default(0)
  totalReturns  Int @default(0)

  totalSales           Decimal @default(0) @db.Decimal(15, 2)
  totalPaid            Decimal @default(0) @db.Decimal(15, 2)
  totalDue             Decimal @default(0) @db.Decimal(15, 2)
  totalDiscount        Decimal @default(0) @db.Decimal(15, 2)
  totalPaymentReceived Decimal @default(0) @db.Decimal(15, 2)
  totalRefund          Decimal @default(0) @db.Decimal(15, 2)
  netRevenue           Decimal @default(0) @db.Decimal(15, 2)

  // Generated file path for PDF, Excel or CSV
  fileUrl String?

  // Error details when generation fails
  errorMessage String? @db.Text

  totalRecords Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy String?
  updatedBy String?

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@index([reportType])
  @@index([status])
  @@index([format])
  @@index([userId])
  @@index([startDate])
  @@index([endDate])
  @@index([createdAt])
  @@index([reportType, year, month])
}
